<!DOCTYPE html>
<html xmlns:o="urn:schemas-microsoft-com:office:office"
      xmlns:w="urn:schemas-microsoft-com:office:word"
      xmlns="http://www.w3.org/TR/REC-html40">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <!--[if gte mso 9]>
  <xml>
    <w:WordDocument>
      <w:View>Print</w:View>
      <w:Zoom>100</w:Zoom>
      <w:DoNotOptimizeForBrowser/>
    </w:WordDocument>
  </xml>
  <![endif]-->
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Arial, Helvetica, sans-serif;
      font-size: 11pt;
      line-height: 1.5;
      color: #222;
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 48px;
      background: #fff;
    }
    h1 { font-size: 22pt; font-weight: 700; color: #111; margin-bottom: 4px; }
    h2 {
      font-size: 12pt;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #111;
      border-bottom: 2px solid #333;
      padding-bottom: 4px;
      margin-top: 20px;
      margin-bottom: 10px;
    }
    h3 { font-size: 11pt; font-weight: 700; color: #111; margin-bottom: 2px; }
    .subtitle { font-size: 12pt; color: #444; font-weight: 400; margin-bottom: 8px; }
    .contact { font-size: 10pt; color: #333; margin-bottom: 4px; }
    .contact a { color: #333; text-decoration: none; }
    .summary { margin-bottom: 6px; }
    .job { margin-bottom: 16px; }
    .job-header { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; }
    .job-title { font-weight: 700; font-size: 11pt; }
    .job-company { font-weight: 600; color: #333; }
    .job-date { font-size: 10pt; color: #555; white-space: nowrap; }
    .job-role { font-style: italic; color: #444; font-size: 10.5pt; margin-bottom: 6px; }
    ul { padding-left: 20px; margin-bottom: 8px; }
    li { margin-bottom: 4px; font-size: 10.5pt; }
    .skills-grid { display: flex; flex-wrap: wrap; gap: 6px 24px; }
    .skill-cat { margin-bottom: 8px; }
    .skill-cat strong { font-size: 10.5pt; }
    .skill-cat span { font-size: 10.5pt; color: #333; }
    .keywords { margin-top: 20px; padding: 12px; background: #f7f7f7; border: 1px solid #e0e0e0; font-size: 9.5pt; color: #555; }
    .keywords strong { color: #333; }
    .score { margin-top: 12px; padding: 12px; background: #eef6ee; border: 1px solid #c4e0c4; }
    .score strong { font-size: 12pt; }
    .divider { border: none; border-top: 1px solid #ddd; margin: 6px 0; }
    @media print {
      body { padding: 24px 36px; }
      .keywords, .score, .ats-section { display: none; }
    }
  </style>
</head>
<body>


